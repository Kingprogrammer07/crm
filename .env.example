# Telegram Bot Token (get from @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# amoCRM Domain (without .amocrm.ru)
AMOCRM_DOMAIN=your_company

# amoCRM Long-term Token (from Integration -> Keys)
AMOCRM_ACCESS_TOKEN=your_amocrm_token_here

# Optional: amoCRM Pipeline ID (for specific sales pipeline)
# AMOCRM_PIPELINE_ID=123456
